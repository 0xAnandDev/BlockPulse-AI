# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://blockpulse:blockpulse@localhost:5432/blockpulse

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Blockchain (Ethereum Sepolia)
# Defaults to a public RPC if unset. For reliability under load, use a dedicated
# provider (Alchemy/Infura) Sepolia endpoint instead.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Monitoring thresholds
LARGE_TRANSFER_THRESHOLD_ETH=1
WALLET_INACTIVE_HOURS=24

# Notifications — Email (optional; unset means email notifications are logged only, not sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Notifications — Telegram (optional; unset means Telegram notifications are logged only, not sent)
TELEGRAM_BOT_TOKEN=
# Shared operator chat until per-user notification preferences exist
TELEGRAM_CHAT_ID=
